generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  STAFF
  ADMIN
}

enum ComplaintStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintCategory {
  HYGIENE
  BILLING
  STAFF_BEHAVIOR
  SERVICE_DELAY
  EQUIPMENT
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  ASSIGNMENT
  RESOLUTION
  RESPONSE
  NEW_COMPLAINT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         Role
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  jobTitle     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  responses            ComplaintResponse[]
  notifications        Notification[]
  assignedComplaints   Complaint[]         @relation("AssignedStaff")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  head        String?
  description String?
  staffCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  complaints  Complaint[]
}

model Complaint {
  id               String            @id @default(cuid())
  ticketId         String            @unique
  patientName      String
  patientEmail     String
  patientPhone     String
  category         ComplaintCategory
  departmentId     String
  department       Department        @relation(fields: [departmentId], references: [id])
  description      String            @db.Text
  status           ComplaintStatus   @default(SUBMITTED)
  priority         Priority          @default(MEDIUM)
  assignedStaffId  String?
  assignedStaff    User?             @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  responses     ComplaintResponse[]
  notifications Notification[]
  attachments   ComplaintAttachment[]
}

model ComplaintAttachment {
  id             String    @id @default(cuid())
  complaintId    String
  complaint      Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  originalName   String
  storedFileName String
  mimeType       String
  sizeBytes      Int
  createdAt      DateTime  @default(now())

  @@index([complaintId])
}

model ComplaintResponse {
  id           String           @id @default(cuid())
  complaintId  String
  complaint    Complaint        @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  authorId     String
  author       User             @relation(fields: [authorId], references: [id])
  message      String           @db.Text
  statusChange ComplaintStatus?
  createdAt    DateTime         @default(now())

  @@index([complaintId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String           @db.Text
  read        Boolean          @default(false)
  complaintId String?
  complaint   Complaint?       @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())

  @@index([userId, read])
}
