NODE_ENV=development
PORT=4000
HOST=0.0.0.0
# Optional: full URL shown in startup logs (e.g. behind a proxy). Defaults to http://localhost:{PORT}
# PUBLIC_BASE_URL=https://api.example.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_cm?schema=public
JWT_SECRET=replace-with-at-least-32-characters-secret-key!!
JWT_EXPIRES_IN=7d
# Short-lived token after correct password when 2FA is enabled (RFC 6238 TOTP)
# JWT_2FA_EXPIRES_IN=5m
# TOTP_ISSUER=SmartCare
# Comma-separated list of allowed browser origins (no spaces required). Use * for any origin (dev only).
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional: leave empty to disable Redis caching
REDIS_URL=

# Optional: leave MAIL_HOST empty to log emails only (no SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Hospital CM <noreply@hospital.local>"

# Complaint file uploads (created on disk under this directory)
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_MB=5

# In-process categorization (TypeScript): local NLP then optional Transformers.js / DistilBERT-MNLI
# CATEGORIZATION_LOCAL_THRESHOLD=0.42
# CATEGORIZATION_HF_ENABLED=true
# CATEGORIZATION_HF_MODEL=Xenova/distilbert-base-uncased-mnli
